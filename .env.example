# Same value as EXPO_PUBLIC_NEULAND_AUTHENTIK_CLIENT_ID in the app (JWT aud)
NEULAND_AUTHENTIK_CLIENT_ID=

# JWT iss claim; JWKS URL is derived automatically (<issuer>jwks/)
NEULAND_AUTHENTIK_ISSUER=https://auth.neuland.ing/application/o/next/

# Hours until a check-in expires automatically (default: 5)
OFFICE_PRESENCE_TIMEOUT_HOURS=5
